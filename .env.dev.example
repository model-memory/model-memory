# Template for .env.dev. Copy to `.env.dev` and fill in values.
# Load with:  set -a; source .env.dev; set +a

# Cloudflare account ID (same value as in wrangler whoami).
CLOUDFLARE_ACCOUNT_ID=""

# Scoped API token for reading Workers Builds.
#
# This must be a USER API token (cfut_ prefix), scoped Read-Only across the
# entire project. It is what the Workers Build Configuration writes when you
# create a token from:
#   Dashboard → your Worker → Settings → Build → Build configuration
#
# Permissions:
#   - Account · Workers Scripts:Read
#   - Account · Workers Observability:Read
# Scope to the model-memory account only. Use a short TTL.
#
# Do NOT confuse this with an ACCOUNT API token. Account tokens are issued for
# Workers CI (a different surface) and live under a different section of the
# dashboard. If you see "Workers CI" instead of "Workers Build Configuration"
# while creating the token, you are in the wrong place — back out and use the
# per-Worker Build configuration flow above.
CLOUDFLARE_API_TOKEN=""
